# Copia questo file in .env e compila i valori.
# .env e' in .gitignore: NON committarlo mai.

# Verifica su BscScan (chiave Etherscan V2, vale per tutte le chain):
# https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Indirizzi dei ruoli (su testnet possono restare vuoti: default = deployer,
# lo script logga un warning; in produzione DEVONO essere multisig distinti)
GUARDIAN_ADDRESS=
MARKETING_WALLET=
TREASURY_ADDRESS=

# Vecchio token Daimon. Vuoto = lo script deploya MockOldDaimon (testnet).
# OLD_DAIMON=
# OLD_SUPPLY=1000000000000000000000000000

# Durata della finestra di migrazione in secondi (default 30 giorni)
# MIGRATION_DURATION=2592000

# SOLO per l'opzione B (sconsigliata) di DEPLOY.md: chiave privata in env.
# Preferisci il keystore cifrato (cast wallet import), vedi DEPLOY.md.
# PRIVATE_KEY=
